{
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "buildArgs": {
      "NODE_ENV": "production",
      "BUILD_TIMESTAMP": "${NOW}"
    }
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5,
    "port": 8080,
    "replicas": 1,
    "resources": {
      "cpu": "500m",
      "memory": "256Mi"
    }
  },
  "env": {
    "NODE_ENV": "production",
    "PORT": "8080",
    "NODE_OPTIONS": "--max-old-space-size=200",
    "REDIS_ENABLED": "false",
    "MONGODB_URI": "mongodb://localhost:27017/flulink"
  },
  "healthCheck": {
    "path": "/api/health",
    "interval": 30,
    "timeout": 10,
    "retries": 3
  },
  "domains": [
    "flulink-backend-v2.zeabur.app"
  ]
}
