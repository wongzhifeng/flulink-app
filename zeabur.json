{
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "flulink/backend/Dockerfile",
    "buildArgs": {
      "NODE_ENV": "production",
      "BUILD_TIMESTAMP": "${NOW}"
    }
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "port": 8080,
    "replicas": 1,
    "resources": {
      "cpu": "1000m",
      "memory": "512Mi"
    }
  },
  "env": {
    "NODE_ENV": "production",
    "PORT": "8080",
    "NODE_OPTIONS": "--max-old-space-size=512"
  },
  "healthCheck": {
    "path": "/api/health",
    "interval": 30,
    "timeout": 10,
    "retries": 3
  },
  "domains": [
    "flulink-app.zeabur.app"
  ]
}
