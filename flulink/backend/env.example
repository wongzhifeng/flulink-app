# FluLink 环境配置

# 服务器配置
PORT=3001
NODE_ENV=development

# MongoDB配置
MONGODB_URL=mongodb://localhost:27017/flulink

# Redis配置（可禁用）
# 将 REDIS_ENABLED 设为 false 可禁用 Redis（如无可用实例时）
REDIS_ENABLED=true

# 优先使用 ZEABUR_REDIS_URL 或 REDIS_URL（支持 rediss:// TLS）
ZEABUR_REDIS_URL=
REDIS_URL=
REDIS_TLS=false

# 备用参数（未提供 URL 时使用）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT配置
JWT_SECRET=flulink-secret-key-2024
JWT_EXPIRES_IN=7d

# 管理员配置
ADMIN_PHONE=13800138000

# 文件上传配置
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp

# 星团配置
CLUSTER_SIZE=49
CLUSTER_EXPIRE_DAYS=7

# 共鸣计算配置
RESONANCE_TAG_WEIGHT=0.6
RESONANCE_INTERACTION_WEIGHT=0.4
RESONANCE_RANDOM_WEIGHT=0.05

# 星种配置
STARSEED_INITIAL_LUMINOSITY=10
STARSEED_JUMP_THRESHOLD=70
STARSEED_LUMINOSITY_DECAY_RATE=0.05

# 缓存配置
CACHE_TTL_CLUSTER=3600
CACHE_TTL_USER_ACTIVE=300
CACHE_TTL_RESONANCE=1800
CACHE_TTL_SEED_HOT=600

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/app.log

# 安全配置
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# 跨域配置
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

