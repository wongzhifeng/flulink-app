<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息 -->
  <view class="page-container">
    <view class="user-header">
      <view class="user-avatar">
        <image class="avatar-image" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFit"></image>
      </view>
      <view class="user-info">
        <text class="user-name">{{userInfo.nickName || '未登录用户'}}</text>
        <text class="user-id">ID: {{userInfo.openid || '未知'}}</text>
        <text class="user-location">{{location.address || '位置未知'}}</text>
      </view>
      <button wx:if="{{!userInfo}}" class="btn btn-small btn-primary" bindtap="login">登录</button>
    </view>
  </view>

  <!-- 个人统计 -->
  <view class="page-container">
    <view class="card-header">
      <image class="card-icon" src="/images/personal-icon.png" mode="aspectFit"></image>
      <text class="card-title">个人统计</text>
    </view>
    
    <view class="personal-stats">
      <view class="stat-item">
        <view class="stat-number">{{personalStats.createdStrains}}</view>
        <text class="stat-label">创建毒株</text>
      </view>
      <view class="stat-item">
        <view class="stat-number">{{personalStats.infectionCount}}</view>
        <text class="stat-label">感染次数</text>
      </view>
      <view class="stat-item">
        <view class="stat-number">{{personalStats.spreadCount}}</view>
        <text class="stat-label">传播次数</text>
      </view>
      <view class="stat-item">
        <view class="stat-number">{{personalStats.rank}}</view>
        <text class="stat-label">传播排名</text>
      </view>
    </view>
  </view>

  <!-- 我的毒株 -->
  <view class="page-container">
    <view class="card-header">
      <image class="card-icon" src="/images/my-strains-icon.png" mode="aspectFit"></image>
      <text class="card-title">我的毒株</text>
      <button class="btn btn-small btn-secondary" bindtap="viewAllStrains">查看全部</button>
    </view>
    
    <view wx:if="{{myStrains.length > 0}}" class="my-strains">
      <view wx:for="{{myStrains}}" wx:key="id" class="strain-item" bindtap="viewStrainDetail" data-id="{{item.id}}">
        <view class="strain-content">
          <text class="strain-title">{{item.title}}</text>
          <text class="strain-desc">{{item.content}}</text>
          <view class="strain-meta">
            <text class="tag tag-primary">{{item.type}}</text>
            <text class="strain-infections">{{item.infections}}人感染</text>
            <text class="strain-time">{{item.timeAgo}}</text>
          </view>
        </view>
        <image class="strain-arrow" src="/images/arrow-right.png" mode="aspectFit"></image>
      </view>
    </view>
    
    <view wx:else class="empty-state">
      <image class="empty-icon" src="/images/empty-my-strains.png" mode="aspectFit"></image>
      <text class="empty-text">还没有创建毒株</text>
      <text class="empty-desc">发布第一个毒株开始传播吧！</text>
      <button class="btn btn-primary" bindtap="goToPublish">发布毒株</button>
    </view>
  </view>

  <!-- 我的收藏 -->
  <view class="page-container">
    <view class="card-header">
      <image class="card-icon" src="/images/collect-icon.png" mode="aspectFit"></image>
      <text class="card-title">我的收藏</text>
      <button class="btn btn-small btn-secondary" bindtap="viewAllCollections">查看全部</button>
    </view>
    
    <view wx:if="{{collections.length > 0}}" class="collections">
      <view wx:for="{{collections}}" wx:key="id" class="collection-item" bindtap="viewStrainDetail" data-id="{{item.id}}">
        <view class="collection-content">
          <text class="collection-title">{{item.title}}</text>
          <text class="collection-desc">{{item.content}}</text>
          <view class="collection-meta">
            <text class="tag tag-success">{{item.type}}</text>
            <text class="collection-time">{{item.collectedTime}}</text>
          </view>
        </view>
        <image class="collection-arrow" src="/images/arrow-right.png" mode="aspectFit"></image>
      </view>
    </view>
    
    <view wx:else class="empty-state">
      <image class="empty-icon" src="/images/empty-collections.png" mode="aspectFit"></image>
      <text class="empty-text">还没有收藏毒株</text>
      <text class="empty-desc">去发现有趣的毒株吧！</text>
    </view>
  </view>

  <!-- 设置选项 -->
  <view class="page-container">
    <view class="card-header">
      <image class="card-icon" src="/images/settings-icon.png" mode="aspectFit"></image>
      <text class="card-title">设置</text>
    </view>
    
    <view class="settings-list">
      <view class="setting-item" bindtap="updateLocation">
        <image class="setting-icon" src="/images/location-icon.png" mode="aspectFit"></image>
        <text class="setting-label">更新位置</text>
        <text class="setting-value">{{location.address || '未设置'}}</text>
        <image class="setting-arrow" src="/images/arrow-right.png" mode="aspectFit"></image>
      </view>
      
      <view class="setting-item" bindtap="notificationSettings">
        <image class="setting-icon" src="/images/notification-icon.png" mode="aspectFit"></image>
        <text class="setting-label">通知设置</text>
        <switch checked="{{notificationEnabled}}" bindchange="toggleNotification" />
      </view>
      
      <view class="setting-item" bindtap="privacySettings">
        <image class="setting-icon" src="/images/privacy-icon.png" mode="aspectFit"></image>
        <text class="setting-label">隐私设置</text>
        <image class="setting-arrow" src="/images/arrow-right.png" mode="aspectFit"></image>
      </view>
      
      <view class="setting-item" bindtap="aboutApp">
        <image class="setting-icon" src="/images/about-icon.png" mode="aspectFit"></image>
        <text class="setting-label">关于应用</text>
        <image class="setting-arrow" src="/images/arrow-right.png" mode="aspectFit"></image>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view wx:if="{{userInfo}}" class="page-container">
    <button class="btn btn-block btn-danger" bindtap="logout">退出登录</button>
  </view>
</view>
