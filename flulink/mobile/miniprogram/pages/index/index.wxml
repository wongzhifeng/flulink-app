<!--pages/index/index.wxml-->
<view class="container">
  <!-- 头部统计卡片 -->
  <view class="page-container">
    <view class="card-header">
      <image class="card-icon" src="/images/virus-icon.png" mode="aspectFit"></image>
      <text class="card-title">FluLink 流感传播</text>
    </view>
    
    <!-- 实时统计数据 -->
    <view class="stats-grid">
      <view class="stat-card">
        <view class="stat-number">{{stats.totalStrains}}</view>
        <view class="stat-label">总毒株数</view>
      </view>
      <view class="stat-card">
        <view class="stat-number">{{stats.totalInfections}}</view>
        <view class="stat-label">总感染数</view>
      </view>
      <view class="stat-card">
        <view class="stat-number">{{stats.activeUsers}}</view>
        <view class="stat-label">活跃用户</view>
      </view>
      <view class="stat-card">
        <view class="stat-number">{{stats.coverage}}%</view>
        <view class="stat-label">覆盖率</view>
      </view>
    </view>
    
    <!-- 更新时间 -->
    <view class="update-time">
      <text class="update-text">最后更新: {{lastUpdateTime}}</text>
      <button class="btn btn-small btn-secondary" bindtap="refreshData">刷新</button>
    </view>
  </view>

  <!-- 附近毒株列表 -->
  <view class="page-container">
    <view class="card-header">
      <image class="card-icon" src="/images/nearby-icon.png" mode="aspectFit"></image>
      <text class="card-title">附近毒株</text>
    </view>
    
    <view wx:if="{{nearbyStrains.length > 0}}" class="list">
      <view wx:for="{{nearbyStrains}}" wx:key="id" class="list-item" bindtap="viewStrainDetail" data-id="{{item.id}}">
        <view class="list-item-content">
          <view class="list-item-title">{{item.title}}</view>
          <view class="list-item-desc">{{item.content}}</view>
          <view class="list-item-meta">
            <text class="tag tag-primary">{{item.type}}</text>
            <text class="distance">{{item.distance}}m</text>
            <text class="infections">{{item.infections}}人感染</text>
          </view>
        </view>
        <image class="list-item-arrow" src="/images/arrow-right.png" mode="aspectFit"></image>
      </view>
    </view>
    
    <view wx:else class="empty-state">
      <image class="empty-icon" src="/images/empty-strains.png" mode="aspectFit"></image>
      <text class="empty-text">附近暂无毒株</text>
      <text class="empty-desc">发布第一个毒株开始传播吧！</text>
    </view>
  </view>

  <!-- 快速操作 -->
  <view class="page-container">
    <view class="card-header">
      <image class="card-icon" src="/images/action-icon.png" mode="aspectFit"></image>
      <text class="card-title">快速操作</text>
    </view>
    
    <view class="action-grid">
      <button class="action-btn" bindtap="goToPublish">
        <image class="action-icon" src="/images/publish-icon.png" mode="aspectFit"></image>
        <text class="action-text">发布毒株</text>
      </button>
      <button class="action-btn" bindtap="goToNearby">
        <image class="action-icon" src="/images/nearby-icon.png" mode="aspectFit"></image>
        <text class="action-text">查看附近</text>
      </button>
      <button class="action-btn" bindtap="goToDashboard">
        <image class="action-icon" src="/images/dashboard-icon.png" mode="aspectFit"></image>
        <text class="action-text">数据看板</text>
      </button>
      <button class="action-btn" bindtap="goToProfile">
        <image class="action-icon" src="/images/profile-icon.png" mode="aspectFit"></image>
        <text class="action-text">个人中心</text>
      </button>
    </view>
  </view>

  <!-- 系统状态 -->
  <view class="page-container">
    <view class="card-header">
      <image class="card-icon" src="/images/status-icon.png" mode="aspectFit"></image>
      <text class="card-title">系统状态</text>
    </view>
    
    <view class="status-list">
      <view class="status-item">
        <text class="status-label">登录状态</text>
        <text class="status-value {{userInfo ? 'status-success' : 'status-error'}}">
          {{userInfo ? '已登录' : '未登录'}}
        </text>
      </view>
      <view class="status-item">
        <text class="status-label">位置信息</text>
        <text class="status-value {{location ? 'status-success' : 'status-error'}}">
          {{location ? location.address : '未获取'}}
        </text>
      </view>
      <view class="status-item">
        <text class="status-label">实时连接</text>
        <text class="status-value {{websocketConnected ? 'status-success' : 'status-error'}}">
          {{websocketConnected ? '已连接' : '未连接'}}
        </text>
      </view>
    </view>
  </view>
</view>

<!-- 悬浮发布按钮 -->
<button class="floating-btn" bindtap="goToPublish">
  <image class="floating-icon" src="/images/add-icon.png" mode="aspectFit"></image>
</button>
