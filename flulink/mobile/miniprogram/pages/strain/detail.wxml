<!--pages/strain/detail.wxml-->
<view class="container">
  <!-- 毒株详情 -->
  <view wx:if="{{strain}}" class="page-container">
    <view class="strain-header">
      <view class="strain-type">
        <text class="type-tag {{strain.type}}">{{strain.typeName}}</text>
      </view>
      <view class="strain-meta">
        <text class="strain-time">{{strain.timeAgo}}</text>
        <text class="strain-distance">{{strain.distance}}m</text>
      </view>
    </view>
    
    <view class="strain-content">
      <text class="strain-title">{{strain.title}}</text>
      <text class="strain-desc">{{strain.content}}</text>
    </view>
    
    <view wx:if="{{strain.image}}" class="strain-image">
      <image class="content-image" src="{{strain.image}}" mode="aspectFit" bindtap="previewImage"></image>
    </view>
    
    <view wx:if="{{strain.form}}" class="strain-form">
      <text class="form-title">{{strain.form.title}}</text>
      <view class="form-options">
        <view wx:for="{{strain.form.options}}" wx:key="index" 
              class="form-option {{selectedOption === index ? 'form-option-selected' : ''}}"
              bindtap="selectOption" data-index="{{index}}">
          <text class="option-text">{{item}}</text>
          <view wx:if="{{selectedOption === index}}" class="option-check">
            <image src="/images/check-icon.png" mode="aspectFit"></image>
          </view>
        </view>
      </view>
    </view>
    
    <view class="strain-stats">
      <view class="stat-item">
        <image class="stat-icon" src="/images/infection-icon.png" mode="aspectFit"></image>
        <text class="stat-label">感染人数</text>
        <text class="stat-value">{{strain.infections}}</text>
      </view>
      <view class="stat-item">
        <image class="stat-icon" src="/images/toxicity-icon.png" mode="aspectFit"></image>
        <text class="stat-label">毒性评分</text>
        <text class="stat-value {{getToxicityClass(strain.toxicity)}}">{{strain.toxicity}}/10</text>
      </view>
      <view class="stat-item">
        <image class="stat-icon" src="/images/spread-icon.png" mode="aspectFit"></image>
        <text class="stat-label">传播次数</text>
        <text class="stat-value">{{strain.spreads}}</text>
      </view>
    </view>
  </view>

  <!-- 传播历史 -->
  <view class="page-container">
    <view class="card-header">
      <image class="card-icon" src="/images/history-icon.png" mode="aspectFit"></image>
      <text class="card-title">传播历史</text>
    </view>
    
    <view wx:if="{{spreadHistory.length > 0}}" class="spread-history">
      <view wx:for="{{spreadHistory}}" wx:key="index" class="history-item">
        <view class="history-time">{{item.time}}</view>
        <view class="history-content">
          <text class="history-desc">{{item.description}}</text>
          <text class="history-location">{{item.location}}</text>
        </view>
        <view class="history-status {{item.status}}">
          <text class="status-text">{{item.statusText}}</text>
        </view>
      </view>
    </view>
    
    <view wx:else class="empty-state">
      <image class="empty-icon" src="/images/empty-history.png" mode="aspectFit"></image>
      <text class="empty-text">暂无传播历史</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <button class="btn btn-block btn-primary btn-large" 
            bindtap="infectStrain"
            disabled="{{infecting}}">
      {{infecting ? '感染中...' : '感染此毒株'}}
    </button>
    
    <view class="action-row">
      <button class="btn btn-secondary" bindtap="shareStrain">
        <image class="btn-icon" src="/images/share-icon.png" mode="aspectFit"></image>
        <text class="btn-text">分享</text>
      </button>
      <button class="btn btn-secondary" bindtap="reportStrain">
        <image class="btn-icon" src="/images/report-icon.png" mode="aspectFit"></image>
        <text class="btn-text">举报</text>
      </button>
      <button class="btn btn-secondary" bindtap="collectStrain">
        <image class="btn-icon" src="/images/collect-icon.png" mode="aspectFit"></image>
        <text class="btn-text">{{collected ? '已收藏' : '收藏'}}</text>
      </button>
    </view>
  </view>
</view>

<!-- 加载状态 -->
<view wx:if="{{loading}}" class="loading-overlay">
  <view class="loading-content">
    <image class="loading-icon" src="/images/loading-icon.png" mode="aspectFit"></image>
    <text class="loading-text">加载中...</text>
  </view>
</view>
