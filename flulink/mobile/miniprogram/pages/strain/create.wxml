<!--pages/strain/create.wxml-->
<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">发布毒株</text>
    <text class="page-subtitle">让内容像流感一样传播</text>
  </view>

  <!-- 毒株类型选择 -->
  <view class="page-container">
    <view class="card-header">
      <image class="card-icon" src="/images/type-icon.png" mode="aspectFit"></image>
      <text class="card-title">选择毒株类型</text>
    </view>
    
    <view class="type-selector">
      <view wx:for="{{strainTypes}}" wx:key="value" 
            class="type-item {{selectedType === item.value ? 'type-item-active' : ''}}"
            bindtap="selectType" data-type="{{item.value}}">
        <image class="type-icon" src="{{item.icon}}" mode="aspectFit"></image>
        <text class="type-name">{{item.name}}</text>
        <text class="type-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 内容输入区域 -->
  <view class="page-container">
    <view class="card-header">
      <image class="card-icon" src="/images/content-icon.png" mode="aspectFit"></image>
      <text class="card-title">输入内容</text>
    </view>
    
    <!-- 文本类型 -->
    <view wx:if="{{selectedType === 'text'}}" class="input-group">
      <text class="input-label">文本内容</text>
      <textarea class="input textarea" 
                placeholder="输入你想要传播的内容..." 
                value="{{content.text}}"
                bindinput="onTextInput"
                maxlength="500"
                show-confirm-bar="{{false}}"></textarea>
      <view class="char-count">{{content.text.length}}/500</view>
    </view>
    
    <!-- 图片类型 -->
    <view wx:if="{{selectedType === 'image'}}" class="input-group">
      <text class="input-label">选择图片</text>
      <view class="image-uploader">
        <view wx:if="{{!content.image}}" class="upload-placeholder" bindtap="chooseImage">
          <image class="upload-icon" src="/images/upload-icon.png" mode="aspectFit"></image>
          <text class="upload-text">点击选择图片</text>
        </view>
        <view wx:else class="image-preview">
          <image class="preview-image" src="{{content.image}}" mode="aspectFit"></image>
          <view class="image-actions">
            <button class="btn btn-small btn-secondary" bindtap="chooseImage">重新选择</button>
            <button class="btn btn-small btn-danger" bindtap="removeImage">删除</button>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 表单类型 -->
    <view wx:if="{{selectedType === 'form'}}" class="input-group">
      <text class="input-label">表单标题</text>
      <input class="input" 
             placeholder="输入表单标题" 
             value="{{content.form.title}}"
             bindinput="onFormTitleInput" />
      
      <text class="input-label">表单选项</text>
      <view class="form-options">
        <view wx:for="{{content.form.options}}" wx:key="index" class="form-option">
          <input class="input" 
                 placeholder="选项{{index + 1}}" 
                 value="{{item}}"
                 bindinput="onFormOptionInput" 
                 data-index="{{index}}" />
          <button wx:if="{{content.form.options.length > 2}}" 
                  class="btn btn-small btn-danger" 
                  bindtap="removeFormOption" 
                  data-index="{{index}}">删除</button>
        </view>
        <button class="btn btn-small btn-secondary" bindtap="addFormOption">
          <text>+ 添加选项</text>
        </button>
      </view>
    </view>
  </view>

  <!-- 位置信息 -->
  <view class="page-container">
    <view class="card-header">
      <image class="card-icon" src="/images/location-icon.png" mode="aspectFit"></image>
      <text class="card-title">位置信息</text>
    </view>
    
    <view class="location-info">
      <image class="location-icon" src="/images/location-icon.png" mode="aspectFit"></image>
      <view class="location-content">
        <text class="location-text">{{location.address || '正在获取位置...'}}</text>
        <text class="location-coords">{{location.latitude}}, {{location.longitude}}</text>
      </view>
      <button class="btn btn-small btn-secondary" bindtap="updateLocation">更新位置</button>
    </view>
  </view>

  <!-- 传播预测 -->
  <view class="page-container">
    <view class="card-header">
      <image class="card-icon" src="/images/prediction-icon.png" mode="aspectFit"></image>
      <text class="card-title">传播预测</text>
    </view>
    
    <view class="prediction-card">
      <view class="prediction-item">
        <text class="prediction-label">毒性评分</text>
        <view class="toxicity-score {{getToxicityClass(prediction.toxicity)}}">
          {{prediction.toxicity}}/10
        </view>
      </view>
      
      <view class="prediction-item">
        <text class="prediction-label">预计感染人数</text>
        <text class="prediction-value">{{prediction.estimatedInfections}}人</text>
      </view>
      
      <view class="prediction-item">
        <text class="prediction-label">传播延迟</text>
        <text class="prediction-value">{{prediction.delay}}分钟</text>
      </view>
      
      <view class="prediction-item">
        <text class="prediction-label">成功率</text>
        <text class="prediction-value">{{prediction.successRate}}%</text>
      </view>
    </view>
  </view>

  <!-- 发布按钮 -->
  <view class="publish-section">
    <button class="btn btn-block btn-primary btn-large" 
            bindtap="publishStrain"
            disabled="{{!canPublish}}">
      {{publishing ? '发布中...' : '发布毒株'}}
    </button>
  </view>
</view>
