/* pages/strain/detail.wxss */
/* 毒株详情页面样式 */

.strain-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
}

.strain-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.strain-time {
  font-size: 22rpx;
  color: #999;
}

.strain-distance {
  font-size: 22rpx;
  color: #4A90E2;
  font-weight: 500;
}

.strain-content {
  margin-bottom: 25rpx;
}

.strain-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
  line-height: 1.4;
}

.strain-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.strain-image {
  margin-bottom: 25rpx;
}

.content-image {
  width: 100%;
  max-height: 400rpx;
  border-radius: 15rpx;
}

.strain-form {
  margin-bottom: 25rpx;
  padding: 25rpx;
  background-color: #f8f9fa;
  border-radius: 15rpx;
}

.form-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.form-options {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.form-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 15rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.form-option-selected {
  border-color: #4A90E2;
  background-color: #e3f2fd;
}

.option-text {
  font-size: 26rpx;
  color: #333;
}

.option-check {
  width: 30rpx;
  height: 30rpx;
}

.option-check image {
  width: 100%;
  height: 100%;
}

.strain-stats {
  display: flex;
  justify-content: space-around;
  padding: 25rpx;
  background-color: #f8f9fa;
  border-radius: 15rpx;
  margin-bottom: 25rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-icon {
  width: 40rpx;
  height: 40rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #666;
}

.stat-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

/* 传播历史 */
.spread-history {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 15rpx;
}

.history-time {
  width: 80rpx;
  font-size: 22rpx;
  color: #999;
  text-align: center;
}

.history-content {
  flex: 1;
}

.history-desc {
  font-size: 26rpx;
  color: #333;
  display: block;
  margin-bottom: 5rpx;
}

.history-location {
  font-size: 22rpx;
  color: #666;
}

.history-status {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.history-status.success {
  background-color: #e8f5e8;
  color: #2e7d32;
}

.history-status.pending {
  background-color: #fff3e0;
  color: #f57c00;
}

.status-text {
  font-size: 20rpx;
}

/* 操作按钮区域 */
.action-section {
  padding: 30rpx;
  background-color: #fff;
  margin-top: 20rpx;
}

.action-row {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.action-row .btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx;
}

.btn-icon {
  width: 30rpx;
  height: 30rpx;
}

.btn-text {
  font-size: 22rpx;
}

/* 加载覆盖层 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-icon {
  width: 60rpx;
  height: 60rpx;
  animation: rotate 1s linear infinite;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .strain-stats {
    flex-direction: column;
    gap: 20rpx;
  }
  
  .action-row {
    flex-direction: column;
  }
}
